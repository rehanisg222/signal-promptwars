# WARNING: Never put real API keys in this file.
# This file is safe to commit. Real keys go in .env only.

# SIGNAL Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Required: Google Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikey
# This MUST be kept server-side only.
# Do NOT prefix with VITE_ or NEXT_PUBLIC_
GEMINI_API_KEY=

# Optional: Google Maps API Key (for enhanced Places data)
# The app works fully without this key using Wikipedia as the places source.
# Only add this if you want to enhance the places data beyond Wikipedia.
GOOGLE_MAPS_API_KEY=
